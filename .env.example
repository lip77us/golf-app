# Copy this file to .env for local development.
# Never commit .env to git — it is already in .gitignore.

# Django core
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — for local dev only.
# On Railway, DATABASE_URL is injected automatically; leave it unset locally
# if you prefer the explicit DB_* variables below.
# DATABASE_URL=postgres://user:password@localhost:5432/golf_app_db
DB_NAME=golf_app_db
DB_USER=postgres
DB_PASSWORD=your-local-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Golf Course API (golfcourseapi.com)
GOLF_API_KEY=your-api-key-here
GOLF_API_BASE_URL=https://api.golfcourseapi.com

# Logging — set to DEBUG to see full API response bodies
DJANGO_LOG_LEVEL=INFO
